{
  "name": "logos-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A Logos-style compiler for TypeScript: architecture, dependency, and story extraction.",
  "scripts": {
    "dev": "node studio/bin/logos-studio.mjs --port 5175",
    "studio": "node studio/bin/logos-studio.mjs",
    "demo": "tsx src/demo.ts",
    "typecheck": "tsc --noEmit",
    "lint": "node -e \"console.log('Strict lint is optional. Run lint:strict for a cleanup pass.')\"",
    "lint:strict": "eslint src/",
    "test": "vitest run",
    "evals": "tsx evals/run.ts",
    "evals:quick": "tsx evals/run.ts --quick",
    "evals:deterministic": "tsx evals/run.ts --tier deterministic"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ts-morph": "^24.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-plugin-functional": "^10.0.0",
    "playwright": "^1.60.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^2.1.8"
  }
}
