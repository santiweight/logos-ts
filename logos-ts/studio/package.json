{
  "name": "logos-ts-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "logos-studio": "./bin/logos-studio.mjs"
  },
  "scripts": {
    "index": "tsx ../src/build-index.ts ${LOGOS_PROJECT:-../../hn-jobs} src/studio-index.json",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "node -e \"console.log('Strict lint is optional. Run npm run lint:strict for a cleanup pass.')\"",
    "lint:strict": "eslint src/",
    "test": "vitest run",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.0",
    "elkjs": "^0.11.1",
    "react": "^18.3.1",
    "react-arborist": "^3.10.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@storybook/react": "^10.4.4",
    "@storybook/react-vite": "^10.4.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.4.1",
    "eslint-plugin-functional": "^10.0.0",
    "jsdom": "^29.1.1",
    "storybook": "^10.4.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.11",
    "vitest": "^4.1.8"
  }
}
