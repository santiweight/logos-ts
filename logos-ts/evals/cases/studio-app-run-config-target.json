{
  "name": "studio-app-run-config-target",
  "codebase": "../../",
  "comment": {
    "target": "run:studio-app",
    "label": "App",
    "text": "switch the App folder target to be HN Jobs (mini)"
  },
  "agent": "implementation",
  "tier": "deterministic",
  "repeat": 1,
  "timeoutMs": 300000,
  "setup": [
    {
      "oracle": "../checks/studio-app-run-config-target.seed.ts",
      "cwd": ".",
      "cmd": ["pnpm", "exec", "tsx", "studio-app-run-config-target.seed.ts"]
    },
    {
      "oracle": "../checks/studio-app-run-config-target.context.ts",
      "cwd": ".",
      "cmd": ["pnpm", "exec", "tsx", "studio-app-run-config-target.context.ts"]
    }
  ],
  "checks": {
    "typecheck": {
      "cwd": ".",
      "cmd": ["pnpm", "run", "typecheck"]
    },
    "behavior": {
      "oracle": "../checks/studio-app-run-config-target.check.ts",
      "cwd": ".",
      "cmd": ["pnpm", "exec", "tsx", "studio-app-run-config-target.check.ts"]
    }
  }
}
