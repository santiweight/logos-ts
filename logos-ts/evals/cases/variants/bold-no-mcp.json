{
  "name": "bold-no-mcp",
  "codebase": "../../../demos/hn-jobs",
  "comment": {
    "target": "file:app/page.tsx",
    "text": "Make this text bold",
    "selector": ":scope > table > tbody > tr:nth-of-type(1) > td:nth-of-type(2) .role-list > div:nth-of-type(1)",
    "label": "role text"
  },
  "agent": "implementation",
  "checks": {
    "typecheck": {
      "cwd": "",
      "cmd": [
        "pnpm", "exec", "tsc",
        "--noEmit"
      ]
    },
    "behavior": {
      "oracle": "../../checks/bold-role-element.check.test.ts",
      "cwd": "",
      "cmd": [
        "pnpm", "exec", "tsx",
        "--test",
        "bold-role-element.check.test.ts"
      ]
    }
  },
  "tier": "deterministic",
  "repeat": 3,
  "timeoutMs": 60000,
  "skipTestRunner": true
}
