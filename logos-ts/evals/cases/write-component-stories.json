{
  "name": "write-component-stories",
  "codebase": "../../demos/hn-jobs",
  "comment": {
    "target": "component:SearchableFilter",
    "text": "Generate Storybook stories for `SearchableFilter`.",
    "component": "SearchableFilter",
    "label": "SearchableFilter"
  },
  "agent": "implementation",
  "tier": "capability",
  "checks": {
    "typecheck": {
      "cwd": "",
      "cmd": [
        "pnpm", "exec", "tsc",
        "--noEmit"
      ]
    },
    "behavior": {
      "oracle": "../checks/write-component-stories.check.test.tsx",
      "cwd": "",
      "cmd": [
        "node", "--import", "tsx",
        "--test",
        "write-component-stories.check.test.tsx"
      ]
    }
  }
}
