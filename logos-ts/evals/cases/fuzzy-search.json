{
  "name": "fuzzy-search",
  "codebase": "../../demos/hn-jobs",
  "comment": {
    "target": "component:DirectoryPage",
    "label": "DirectoryPage",
    "component": "DirectoryPage",
    "text": "Replace the current search with a server-side fuzzy search. Use an integer score/rank for text matching, support typo-tolerant near matches, display directory results by fuzzy rank when q is present, and keep the existing filters working with search."
  },
  "agent": "implementation",
  "checks": {
    "typecheck": {
      "cwd": "frontend",
      "cmd": [
        "pnpm",
        "exec",
        "tsc",
        "--noEmit"
      ]
    },
    "behavior": {
      "oracle": "../checks/fuzzy-search.check.ts",
      "cwd": "frontend",
      "cmd": [
        "pnpm",
        "exec",
        "tsx",
        "--test",
        "fuzzy-search.check.ts"
      ]
    },
    "rank-api": {
      "oracle": "../checks/fuzzy-search.check.test.ts",
      "cwd": "",
      "cmd": [
        "pnpm",
        "exec",
        "tsx",
        "--test",
        "fuzzy-search.check.test.ts"
      ]
    },
    "project-tests": { "cwd": "", "cmd": ["pnpm", "test"] }
  },
  "tier": "capability"
}
