{
  "name": "rename-company-header",
  "codebase": "../../demos/hn-jobs",
  "comment": {
    "target": "component:DirectoryPage",
    "text": "Rename the 'Company' column header to 'Employer'.",
    "component": "DirectoryPage",
    "storyId": "run:root-app:/",
    "runTargetId": "root-app",
    "appPath": "/",
    "label": "th · Company"
  },
  "agent": "implementation",
  "tier": "deterministic",
  "repeat": 3,
  "checks": {
    "typecheck": {
      "cwd": "frontend",
      "cmd": [
        "pnpm", "exec", "tsc",
        "--noEmit"
      ]
    },
    "behavior": {
      "oracle": [
        "../checks/rename-company-header.check.test.tsx",
        "../checks/source-text.ts"
      ],
      "cwd": "frontend",
      "cmd": [
        "pnpm", "exec", "tsx",
        "--test",
        "rename-company-header.check.test.tsx"
      ]
    }
  }
}
