{
  "name": "bold-role-element",
  "codebase": "../../demos/hn-jobs",
  "comment": {
    "target": "component:DirectoryPage",
    "text": "Make each role line in the Role column render as bold text.",
    "component": "DirectoryPage",
    "storyId": "run:root-app:/",
    "runTargetId": "root-app",
    "appPath": "/",
    "selector": "table.data tbody tr:first-child td:nth-child(2)",
    "label": "role text"
  },
  "agent": "implementation",
  "checks": {
    "typecheck": {
      "cwd": "frontend",
      "cmd": [
        "pnpm", "exec", "tsc",
        "--noEmit"
      ]
    },
    "behavior": {
      "oracle": [
        "../checks/bold-role-element.check.test.tsx",
        "../checks/source-text.ts"
      ],
      "cwd": "frontend",
      "cmd": [
        "pnpm", "exec", "tsx",
        "--test",
        "bold-role-element.check.test.tsx"
      ]
    }
  },
  "tier": "deterministic",
  "repeat": 3,
  "timeoutMs": 60000
}
